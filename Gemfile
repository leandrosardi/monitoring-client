source 'https://rubygems.org'

# specify the ruby version, in order to get bundler  the right version of each gem
ruby '~>3.1.2'

#gem 'json' # stdlib in modern Ruby but explicit for clarity
gem 'pampa', '~>2.1.5'
gem 'simple_cloud_logging', '~>1.2.7'
gem 'simple_command_line_parser', '~>1.1.2'

# Keep Faraday on the 2.3.x line to avoid pulling the modern uri/net-http gems.
gem 'faraday', '~>2.3.0'
gem 'faraday-net_http', '~>2.1.0'